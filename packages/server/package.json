{
  "name": "@apostel/visual-config-server",
  "version": "0.2.0",
  "type": "module",
  "description": "The local daemon: birpc over WebSocket, static UI hosting, script tasks.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sam-Apostel/project-config-tools.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/Sam-Apostel/project-config-tools#readme",
  "bugs": "https://github.com/Sam-Apostel/project-config-tools/issues",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@apostel/visual-config-core": "workspace:*",
    "@apostel/visual-config-protocol": "workspace:*",
    "birpc": "^2.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13"
  }
}
