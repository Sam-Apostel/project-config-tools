{
  "name": "@apostel/visual-config",
  "version": "0.1.1",
  "type": "module",
  "description": "A visual interface for your project's config files.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sam-Apostel/project-config-tools.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Sam-Apostel/project-config-tools#readme",
  "bugs": "https://github.com/Sam-Apostel/project-config-tools/issues",
  "mcpName": "io.github.sam-apostel/visual-config",
  "bin": {
    "visual-config": "./src/bin.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/bin.ts",
    "build": "tsc -p tsconfig.build.json"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "visual-config": "./dist/bin.js"
    }
  },
  "dependencies": {
    "@apostel/visual-config-core": "workspace:*",
    "@apostel/visual-config-mcp": "workspace:*",
    "@apostel/visual-config-server": "workspace:*",
    "@apostel/visual-config-ui": "workspace:*"
  }
}
