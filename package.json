{
  "name": "visual-config-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "description": "A visual interface for your project's config files (monorepo root).",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "pnpm --filter @apostel/visual-config dev",
    "build": "pnpm -r run build",
    "build:ui": "pnpm --filter @apostel/visual-config-ui build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.11",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.10.2",
    "playwright-core": "^1.61.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
