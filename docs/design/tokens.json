{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Facet design tokens — single source of truth for web UI, IDE panels, and docs. Not an implementation; a spec.",
  "meta": {
    "name": "Facet",
    "version": "0.0.0-draft",
    "modes": ["dark", "light"],
    "referenceMode": "dark"
  },
  "color": {
    "neutral": {
      "bg":          { "dark": "#0E1116", "light": "#FBFBFA" },
      "bgSubtle":    { "dark": "#151A21", "light": "#F4F4F2" },
      "surface":     { "dark": "#1B212A", "light": "#FFFFFF" },
      "surfaceHi":   { "dark": "#232B36", "light": "#FFFFFF" },
      "border":      { "dark": "#2A323D", "light": "#E4E4E1" },
      "borderHi":    { "dark": "#3A4552", "light": "#CFCFCB" },
      "text":        { "dark": "#E6E9ED", "light": "#1A1D21" },
      "textMuted":   { "dark": "#9AA4B2", "light": "#5C636E" },
      "textFaint":   { "dark": "#6B7482", "light": "#8A909A" }
    },
    "brand": {
      "brand":      { "dark": "#5B8DEF", "light": "#2F6BE0" },
      "brandHi":    { "dark": "#7BA4F2", "light": "#1E5AD1" },
      "brandQuiet": { "dark": "#1A2536", "light": "#EAF1FE" },
      "focusRing":  { "dark": "#7BA4F2", "light": "#2F6BE0" }
    },
    "status": {
      "ok":           { "dark": "#3FB27F", "light": "#1E8E5A" },
      "okQuiet":      { "dark": "#12241C", "light": "#E4F5EC" },
      "info":         { "dark": "#5B8DEF", "light": "#2F6BE0" },
      "infoQuiet":    { "dark": "#1A2536", "light": "#EAF1FE" },
      "warn":         { "dark": "#E0A44B", "light": "#B87413" },
      "warnQuiet":    { "dark": "#2A2113", "light": "#FBF0DC" },
      "danger":       { "dark": "#E5715F", "light": "#C0392B" },
      "dangerQuiet":  { "dark": "#2A1714", "light": "#FBE7E3" },
      "critical":     { "dark": "#C0455E", "light": "#9B1C3A" },
      "criticalQuiet":{ "dark": "#2A141B", "light": "#F8E1E7" }
    }
  },
  "severity": {
    "critical": "{color.status.critical}",
    "high":     "{color.status.danger}",
    "moderate": "{color.status.warn}",
    "low":      "{color.neutral.textMuted}",
    "info":     "{color.status.info}"
  },
  "font": {
    "family": {
      "sans": "Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace"
    },
    "weight": { "regular": 400, "mono": 450, "semibold": 600 },
    "scale": {
      "display": { "size": "28px", "line": "34px", "weight": 600 },
      "h1":      { "size": "22px", "line": "28px", "weight": 600 },
      "h2":      { "size": "18px", "line": "24px", "weight": 600 },
      "h3":      { "size": "15px", "line": "20px", "weight": 600 },
      "body":    { "size": "14px", "line": "20px", "weight": 400 },
      "small":   { "size": "13px", "line": "18px", "weight": 400 },
      "mono":    { "size": "13px", "line": "20px", "weight": 450 },
      "caption": { "size": "12px", "line": "16px", "weight": 500 }
    }
  },
  "space": {
    "1": "2px", "2": "4px", "3": "8px", "4": "12px",
    "5": "16px", "6": "24px", "7": "32px", "8": "48px", "9": "64px"
  },
  "radius": { "sm": "6px", "md": "10px", "lg": "14px" },
  "shadow": {
    "1": "0 4px 12px rgba(0,0,0,.24)",
    "2": "0 12px 32px rgba(0,0,0,.32)"
  },
  "motion": {
    "duration": { "fast": "120ms", "base": "200ms", "slow": "320ms" },
    "ease": {
      "out": "cubic-bezier(.2,.8,.2,1)",
      "inOut": "cubic-bezier(.4,0,.2,1)"
    }
  },
  "layout": {
    "contentMaxWidth": "960px",
    "railWidth": "216px",
    "inspectorWidth": "420px"
  }
}
